# ===========================================
# AI Tutor Backend - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values

# Database (use PostgreSQL for production)
DATABASE_URL=sqlite:///./ai_tutor.db
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# JWT Authentication (CHANGE THIS!)
SECRET_KEY=CHANGE-THIS-TO-A-RANDOM-SECRET-KEY
ACCESS_TOKEN_EXPIRE_MINUTES=43200

# Model Configuration
BASE_MODEL=mistralai/Mistral-7B-Instruct-v0.2
LORA_PATH=mistral_lora_final

# CORS Origins (comma-separated, add your frontend URL)
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Server
HOST=0.0.0.0
PORT=8000

# Feature Flags
ENABLE_DEMO_ACCOUNTS=true

# Admin Account
ADMIN_EMAIL=admin@aitutor.com
ADMIN_PASSWORD=admin123
ADMIN_NAME=System Admin
